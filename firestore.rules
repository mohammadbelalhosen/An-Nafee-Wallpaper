rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: wallpapers
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - imageUrl: string (required, URL format)
    //   - type: string (required, 'mobile' or 'desktop')
    //   - category: string (optional)
    //   - createdAt: timestamp (required)
    //   - authorId: string (required, matches auth.uid)
    //   - authorEmail: string (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ashfbelal@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidWallpaper(data) {
      return data.imageUrl is string && data.imageUrl.size() < 1000 &&
             data.type in ["mobile", "desktop", "fb_profile", "fb_cover"] &&
             data.createdAt is timestamp &&
             data.authorId == request.auth.uid &&
             (!('creditUrl' in data) || data.creditUrl == null || (data.creditUrl is string && data.creditUrl.size() < 1000));
    }

    function isValidArticle(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() < 50000 &&
             data.createdAt is timestamp &&
             data.authorId == request.auth.uid;
    }

    function isValidVideoPlaylist(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.playlistUrl is string && data.playlistUrl.size() < 1000 &&
             data.createdAt is timestamp;
    }

    match /wallpapers/{wallpaperId} {
      allow read: if true;
      allow create: if isAdmin() && isValidWallpaper(request.resource.data);
      allow update: if isAdmin() && isValidWallpaper(request.resource.data);
      allow delete: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create: if isAdmin() && isValidArticle(request.resource.data);
      allow update: if (isAdmin() && isValidArticle(request.resource.data)) || 
                      (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
      allow delete: if isAdmin();
    }

    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin() && (!('wallpaperRequestUrl' in request.resource.data) || request.resource.data.wallpaperRequestUrl == null || request.resource.data.wallpaperRequestUrl is string);
    }

    match /links/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /apps/{appId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videoPlaylists/{playlistId} {
      allow read: if true;
      allow create: if isAdmin() && isValidVideoPlaylist(request.resource.data);
      allow update: if isAdmin() && isValidVideoPlaylist(request.resource.data);
      allow delete: if isAdmin();
    }

    match /floatingContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
