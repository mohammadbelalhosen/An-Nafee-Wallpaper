{
  "entities": {
    "Wallpaper": {
      "title": "Wallpaper",
      "description": "A wallpaper image for mobile or desktop",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string", "description": "URL of the wallpaper image" },
        "type": { "type": "string", "enum": ["mobile", "desktop", "fb_profile", "fb_cover"], "description": "Type of wallpaper" },
        "category": { "type": "string", "description": "Category (e.g., Nature, Abstract)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "authorId": { "type": "string", "description": "UID of the uploader" }
      },
      "required": ["imageUrl", "type", "createdAt", "authorId"]
    },
    "Article": {
      "title": "Article",
      "description": "A text-based article",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the article" },
        "content": { "type": "string", "description": "HTML content of the article" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "likes": { "type": "number", "description": "Number of likes" },
        "authorId": { "type": "string", "description": "UID of the author" }
      },
      "required": ["title", "content", "createdAt", "authorId"]
    },
    "SiteConfig": {
      "title": "SiteConfig",
      "description": "Global site configuration like hero text",
      "type": "object",
      "properties": {
        "heroHeading": { "type": "string", "description": "Main heading for the hero section" },
        "heroSubHeading": { "type": "string", "description": "Sub-heading for the hero section" }
      }
    }
  },
  "firestore": {
    "wallpapers": {
      "schema": "Wallpaper",
      "description": "Collection of all wallpapers"
    },
    "articles": {
      "schema": "Article",
      "description": "Collection of articles"
    },
    "siteConfig": {
      "schema": "SiteConfig",
      "description": "Global configuration"
    }
  }
}
