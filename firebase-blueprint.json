{
  "entities": {
    "Wallpaper": {
      "title": "Wallpaper",
      "description": "A wallpaper image for mobile or desktop",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string", "description": "URL of the wallpaper image" },
        "type": { "type": "string", "enum": ["mobile", "desktop", "fb_profile", "fb_cover"], "description": "Type of wallpaper" },
        "category": { "type": "string", "description": "Category (e.g., Nature, Abstract)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "authorId": { "type": "string", "description": "UID of the uploader" }
      },
      "required": ["imageUrl", "type", "createdAt", "authorId"]
    },
    "Article": {
      "title": "Article",
      "description": "A text-based article",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the article" },
        "content": { "type": "string", "description": "HTML content of the article" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "likes": { "type": "number", "description": "Number of likes" },
        "authorId": { "type": "string", "description": "UID of the author" }
      },
      "required": ["title", "content", "createdAt", "authorId"]
    },
    "SiteConfig": {
      "title": "SiteConfig",
      "description": "Global site configuration like hero text",
      "type": "object",
      "properties": {
        "heroHeading": { "type": "string", "description": "Main heading for the hero section" },
        "heroSubHeading": { "type": "string", "description": "Sub-heading for the hero section" }
      }
    },
    "LinkItem": {
      "title": "LinkItem",
      "description": "A useful external link",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "createdAt"]
    },
    "AppItem": {
      "title": "AppItem",
      "description": "A useful mobile app",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "playStoreUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "imageUrl", "createdAt"]
    },
    "VideoItem": {
      "title": "VideoItem",
      "description": "A YouTube video",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "videoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "videoUrl", "createdAt"]
    },
    "VideoPlaylist": {
      "title": "VideoPlaylist",
      "description": "A YouTube playlist",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "playlistUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "playlistUrl", "createdAt"]
    },
    "FloatingContent": {
      "title": "FloatingContent",
      "description": "Content for the notice/floating icon",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "wallpapers": {
      "schema": "Wallpaper",
      "description": "Collection of all wallpapers"
    },
    "articles": {
      "schema": "Article",
      "description": "Collection of articles"
    },
    "siteConfig": {
      "schema": "SiteConfig",
      "description": "Global configuration"
    },
    "links": {
      "schema": "LinkItem",
      "description": "Useful links"
    },
    "apps": {
      "schema": "AppItem",
      "description": "Useful apps"
    },
    "videos": {
      "schema": "VideoItem",
      "description": "YouTube videos"
    },
    "videoPlaylists": {
      "schema": "VideoPlaylist",
      "description": "YouTube playlists"
    },
    "floatingContent": {
      "schema": "FloatingContent",
      "description": "Notice content"
    }
  }
}
